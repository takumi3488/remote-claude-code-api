{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "cd remote-claude-code-api && gofmt -w . && go vet ./... && golangci-lint run --fix",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/remote_session_start.sh",
            "type": "command"
          }
        ],
        "matcher": "startup"
      }
    ]
  }
}